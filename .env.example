# ============================================================
# Environment Variables — copy to .env and fill in values
# ============================================================

# Atari game to train/evaluate/play
ATARI_GAME_ID=ALE/Pong-v5

# Path to trained model checkpoint
MODEL_PATH=models/latest_model.pth

# Number of discrete actions for chosen game
# Pong=6, Breakout=4, SpaceInvaders=6
N_ACTIONS=6

# Training episodes override
EPISODES=1000

# Learning rate override
LR=0.0001

# API server port
PORT=8000
